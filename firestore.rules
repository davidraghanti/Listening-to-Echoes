rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if the user has a specific role
    function hasRole(role) {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // Stories Collection
    match /stories/{storyId} {
      // Anyone can submit a story
      allow create: if true;
      
      // Public can only read approved stories. Librarians/Authors can read all.
      allow read: if resource.data.status == 'approved' || hasRole('librarian') || hasRole('author');
      
      // Only librarians can update or delete stories (approval process)
      allow update, delete: if hasRole('librarian');
    }

    // User Profiles Collection
    match /users/{userId} {
      // Users can read/write their own profile. Librarians can read all for the team directory.
      allow read: if request.auth != null && (request.auth.uid == userId || hasRole('librarian'));
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}