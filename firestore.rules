
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if the user has a specific role
    function hasRole(role) {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // Stories Collection
    match /stories/{storyId} {
      allow create: if true;
      allow read: if resource.data.status == 'approved' || hasRole('librarian') || hasRole('author');
      allow update, delete: if hasRole('librarian');
    }

    // User Profiles Collection
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || hasRole('librarian'));
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Access Codes (Lookup only if you know the 10-digit ID)
    match /access_codes/{codeId} {
      allow get: if true;
      allow list: if hasRole('librarian');
    }
  }
}
