
{
  "entities": {
    "Story": {
      "title": "Story",
      "description": "A submitted educational experience story.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "submittedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "audioUrl": { "type": "string" },
        "piiDetected": { "type": "boolean" },
        "tone": { "type": "number", "description": "0 (warm/white) to 100 (dark/black)" }
      },
      "required": ["title", "content", "submittedAt", "status", "tone"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User account details and roles.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "librarian", "author"] }
      }
    },
    "AccessCode": {
      "title": "Access Code",
      "description": "A 10-digit code that grants a specific internal role.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["librarian", "author"] },
        "label": { "type": "string", "description": "Who this code is for." }
      },
      "required": ["role"]
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "/stories/{storyId}": {
      "schema": "Story",
      "description": "Collection of all story submissions."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and permissions."
    },
    "/access_codes/{codeId}": {
      "schema": "AccessCode",
      "description": "Stored 10-digit codes for internal access."
    }
  }
}
